{
  "name": "unsalib-backend",
  "version": "3.0.0",
  "private": true,
  "main": "./dist/server.js",
  "scripts": {
    "dev": "nodemon --watch ./src --exec tsx ./src/server.ts",
    "build": "tsc",
    "start": "node ./dist/server.js",
    "lint": "eslint ./src",
    "fix": "eslint ./src --fix",
    "format": "prettier --write src/**/*.ts",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "type": "module",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "fetch": "^1.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.6",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "node-html-parser": "^7.0.2",
    "socket.io": "^4.8.3",
    "ua-parser-js": "^2.0.9",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.2.0",
    "eslint": "^9.39.2",
    "globals": "^17.3.0",
    "jiti": "^2.6.1",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
